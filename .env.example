# JARVIS environment variables — copy to .env and fill in your keys
# These override config.json values when set.

ELEVENLABS_API_KEY=your_elevenlabs_key_here
SARVAM_API_KEY=your_sarvam_key_here
GROQ_API_KEY=your_groq_key_here

# Optional cloud LLM providers
GEMINI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
